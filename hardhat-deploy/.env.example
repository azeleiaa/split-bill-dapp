# Sepolia deployment secrets
# Fill these in before deploying to Sepolia

# Get from Alchemy: https://alchemy.com or Infura: https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Your MetaMask wallet private key (the account that will pay for deployment)
# Export from MetaMask → Account Details → Export private key
PRIVATE_KEY=your_private_key_here
